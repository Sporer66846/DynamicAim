local function getColorForPlayer(targetPlayer)
    if Visuals.UseTeamColor and targetPlayer.Team then return targetPlayer.TeamColor.Color end
    local baseColor = Visuals.CurrentColor
    if Visuals.InverseFriends and isPlayerFriend(targetPlayer) then
        local h, s, v = baseColor:ToHSV()
        return Color3.fromHSV((h + 0.5) % 1, s, v) 
    end
    return baseColor
end

local function worldToScreen(pos)
    local screenPos, onScreen = Workspace.CurrentCamera:WorldToViewportPoint(pos)
    return Vector2.new(screenPos.X, screenPos.Y), onScreen, screenPos.Z
end

local raycastParams = RaycastParams.new()
raycastParams.FilterType = Enum.RaycastFilterType.Exclude

local function IsVisible(part)
    if not Aimbot.VisibleCheck then return true end
    local char = Player.Character
    if not char then return false end
    
    raycastParams.FilterDescendantsInstances = {char}
    local camera = Workspace.CurrentCamera
    local dir = part.Position - camera.CFrame.Position
    local result = Workspace:Raycast(camera.CFrame.Position, dir, raycastParams)
    
    if result then
        return result.Instance:IsDescendantOf(part.Parent)
    end
    return true
end

-- Triggerbot
local triggerbotDebounce = false
local lastTriggerTime = 0

combatHeartbeat = RunService.Heartbeat:Connect(function()
    if not Combat.Triggerbot or triggerbotDebounce then return end
    
    local now = tick()
    if now - lastTriggerTime < Combat.TriggerDelay then return end
    
    local mouseLoc = UserInputService:GetMouseLocation()
    local camera = Workspace.CurrentCamera
    local ray = camera:ViewportPointToRay(mouseLoc.X, mouseLoc.Y)
    
    raycastParams.FilterDescendantsInstances = {Player.Character}
    local result = Workspace:Raycast(ray.Origin, ray.Direction * 1000, raycastParams)
    
    if not result or not result.Instance then return end
    
    local model = result.Instance:FindFirstAncestorOfClass("Model")
    if not model then return end
    
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then return end
    
    local hitPlayer = Players:GetPlayerFromCharacter(model)
    if not hitPlayer or hitPlayer == Player then return end
    
    if Aimbot.TeamCheck and hitPlayer.Team and Player.Team and hitPlayer.Team == Player.Team then return end
    
    if mouse1press and mouse1release then
        triggerbotDebounce = true
        lastTriggerTime = now
        task.spawn(function()
            mouse1press()
            task.wait(0.05)
            mouse1release()
            task.wait(0.05)
            triggerbotDebounce = false
        end)
    end
end)

-- No Recoil
local lastCameraCFrame = CFrame.new()
local recoilLockThreshold = 0.01
local frameAccumulator = 0

noRecoilRender = RunService.RenderStepped:Connect(function(dt)
    if not Combat.NoRecoil then
        lastCameraCFrame = Workspace.CurrentCamera.CFrame
        return
    end
    
    if Aimbotting then 
        lastCameraCFrame = Workspace.CurrentCamera.CFrame
        return 
    end

    if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
        local delta = UserInputService:GetMouseDelta()
        
        if delta.Magnitude > recoilLockThreshold then
            lastCameraCFrame = Workspace.CurrentCamera.CFrame
            frameAccumulator = 0
        else
            frameAccumulator += dt
            if frameAccumulator > (1/30) then
                local currentCam = Workspace.CurrentCamera
                currentCam.CFrame = CFrame.new(currentCam.CFrame.Position) * lastCameraCFrame.Rotation
            end
        end
    else
        lastCameraCFrame = Workspace.CurrentCamera.CFrame
        frameAccumulator = 0
    end
end)

-- Distance Functions
local function GetPlayerDistance(targetPlayer)
    local targetChar = targetPlayer.Character
    local targetRoot = GetRootPart(targetChar)
    local myRoot = GetRootPart(Player.Character)
    
    if not targetRoot or not myRoot then return math.huge end
    return (targetRoot.Position - myRoot.Position).Magnitude
end

local function GetMouseDistanceToPlayer(targetPlayer)
    local char = targetPlayer.Character
    local root = GetRootPart(char)
    if not root then return math.huge end

    local screenPoint, onScreen, depth = worldToScreen(root.Position)
    if not onScreen or depth <= 0 then return math.huge end

    local mouseLoc = UserInputService:GetMouseLocation()
    local dx = screenPoint.X - mouseLoc.X
    local dy = screenPoint.Y - mouseLoc.Y
    return math.sqrt(dx*dx + dy*dy)
end

local function ValidTargetCheck(targetPlayer)
    if targetPlayer == Player then return false end
    if Aimbot.TeamCheck and targetPlayer.Team and Player.Team and targetPlayer.Team == Player.Team then return false end
    
    local char = targetPlayer.Character
    if not char then return false end
    
    local hum = GetHumanoid(char)
    if not hum or hum.Health <= 0 then return false end
    
    local targetPartName = Aimbot.TargetPart == "Legit" and "Head" or Aimbot.TargetPart
    local part = char:FindFirstChild(targetPartName) or GetRootPart(char)
    if not part then return false end
    
    return IsVisible(part)
end

-- Target Acquisition
local playerListCache = {}
local lastPlayerCacheUpdate = 0

local function GetAimbotTarget()
    local now = tick()
    if now - lastPlayerCacheUpdate > (1/60) then
        playerListCache = Players:GetPlayers()
        lastPlayerCacheUpdate = now
    end
    
    local bestTarget = nil
    local bestScore = math.huge
    
    if Aimbot.Filtering == "ClosestToMouse" then
        local shortestDistance = Aimbot.FOV
        for _, p in ipairs(playerListCache) do
            if ValidTargetCheck(p) then
                local dist2d = GetMouseDistanceToPlayer(p)
                if dist2d < shortestDistance then
                    local pDist = GetPlayerDistance(p)
                    if pDist <= Aimbot.Range then
                        shortestDistance = dist2d
                        bestTarget = p
                    end
                end
            end
        end
    elseif Aimbot.Filtering == "ClosestToPlayer" then
        for _, p in ipairs(playerListCache) do
            if ValidTargetCheck(p) then
                local dist = GetPlayerDistance(p)
                if dist < bestScore then
                    local checkFOV = GetMouseDistanceToPlayer(p)
                    if checkFOV < Aimbot.FOV then
                        bestTarget = p
                        bestScore = dist
                    end
                end
            end
        end
    elseif Aimbot.Filtering == "LowestHealth" then
        for _, p in ipairs(playerListCache) do
            if ValidTargetCheck(p) then
                local dist = GetPlayerDistance(p)
                local checkFOV = GetMouseDistanceToPlayer(p)
                if dist <= Aimbot.Range and checkFOV < Aimbot.FOV then
                    local hum = GetHumanoid(p.Character)
                    if hum and hum.Health < bestScore then
                        bestTarget = p
                        bestScore = hum.Health
                    end
                end
            end
        end
    end
    
    return bestTarget
end


-- Friend Cache with TTL
local friendCache = {}
local cacheTimestamps = {}
local CACHE_TTL = 300

local function isPlayerFriend(targetPlayer)
    local now = os.clock()
    local cached = friendCache[targetPlayer.UserId]
    local timestamp = cacheTimestamps[targetPlayer.UserId]
    
    if cached ~= nil and timestamp and (now - timestamp) < CACHE_TTL then
        return cached
    end
    
    task.spawn(function()
        local success, result = pcall(function() return Player:IsFriendsWith(targetPlayer.UserId) end)
        if success then 
            friendCache[targetPlayer.UserId] = result
            cacheTimestamps[targetPlayer.UserId] = now
        end
    end)
    
    return cached or false
end


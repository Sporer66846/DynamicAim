-- NoClip with proper state management
local function UpdateNoClipState()
    if Main.NoClipEnabled then
        if Noclipping then return end
        ClippingParts = {}
        Noclipping = RunService.Stepped:Connect(function()
            local char = Player.Character
            if not char then return end
            for _, child in pairs(char:GetDescendants()) do
                if child:IsA("BasePart") and child.CanCollide then
                    child.CanCollide = false
                    if not table.find(ClippingParts, child) then
                        table.insert(ClippingParts, child)
                    end
                end
            end
        end)
    else
        if Noclipping then
            Noclipping:Disconnect()
            Noclipping = nil
        end
        for _, part in pairs(ClippingParts) do
            if part and part.Parent then part.CanCollide = true end
        end
        ClippingParts = {}
    end
end


    end

    local now = tick()
    if now - lastPredUpdate < (1/30) then return end
    lastPredUpdate = now

    local bestTarget = Target or GetAimbotTarget()
    if not bestTarget then
        PredDotDrawing.Visible = false
        return
    end
    
    local char = bestTarget.Character
    if not char then
        PredDotDrawing.Visible = false
        return
    end
    
    local rootPart = GetRootPart(char)
    if not rootPart then
        PredDotDrawing.Visible = false
        return
    end

    local targetPartName = Aimbot.TargetPart == "Legit" and "Head" or Aimbot.TargetPart
    local part = char:FindFirstChild(targetPartName) or rootPart
    
    local position = part.Position
    
    if Aimbot.Prediction and Aimbot.BulletSpeed > 0 then
        local distance = (position - Workspace.CurrentCamera.CFrame.Position).Magnitude
        local bulletTravelTime = distance / Aimbot.BulletSpeed
        
        local targetVelocity = rootPart.AssemblyLinearVelocity or rootPart.Velocity
        if targetVelocity and targetVelocity.Magnitude > 0 then
            position = position + (targetVelocity * bulletTravelTime)
        end
        
        if Aimbot.BulletDrop and Aimbot.BulletDropAmount > 0 then
            local drop = 0.5 * Aimbot.BulletDropAmount * (bulletTravelTime * bulletTravelTime)
            position = Vector3.new(position.X, position.Y + drop, position.Z)
        end
    end
    
    local screenPos, onScreen = Workspace.CurrentCamera:WorldToViewportPoint(position)
    if onScreen then
        PredDotDrawing.Position = Vector2.new(screenPos.X, screenPos.Y)
        PredDotDrawing.Visible = true
    else
        PredDotDrawing.Visible = false
    end
end

-- ESP Loop
local highlightPool = {}
local function GetPooledHighlight()
    for i, hl in ipairs(highlightPool) do
        if not hl.Parent then
            table.remove(highlightPool, i)
            return hl
        end
    end
    local hl = Instance.new("Highlight")
    hl.FillTransparency = 1
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    return hl
end


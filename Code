-- FIXED: Responsive Aimbot with original smoothing algorithm
local function aimbotKeyDown()
    if not Aimbot.Enabled then return end
    if Aimbotting then return end

    Target = GetAimbotTarget()
    if not Target then return end

    local switchInterval = 0.3
    local lastSwitchTime = 0
    local currentPart = nil
    local camera = Workspace.CurrentCamera

    Aimbotting = RunService.RenderStepped:Connect(function(dt)
        if not Target or not Target.Character then
            Aimbotting:Disconnect()
            Aimbotting = nil
            Target = nil
            return
        end
        
        local hum = GetHumanoid(Target.Character)
        if not hum or hum.Health <= 0 then
            Aimbotting:Disconnect()
            Aimbotting = nil
            Target = nil
            return
        end

        local rootPart = GetRootPart(Target.Character)
        if not rootPart then return end

        local position
        if Aimbot.TargetPart ~= "Legit" then
            local part = Target.Character:FindFirstChild(Aimbot.TargetPart)
            if not part then return end
            position = part.Position
            currentPart = nil
        else
            local now = os.clock()
            if not currentPart or now - lastSwitchTime >= switchInterval then
                lastSwitchTime = now
                local parts = {
                    Target.Character:FindFirstChild("Head"), 
                    Target.Character:FindFirstChild("UpperTorso") or Target.Character:FindFirstChild("Torso"), 
                    rootPart
                }
                local validParts = {}
                for _, part in ipairs(parts) do
                    if part then table.insert(validParts, part) end
                end
                currentPart = validParts[math.random(1, #validParts)] or rootPart
            end
            position = currentPart.Position
        end

        if Aimbot.Prediction and Aimbot.BulletSpeed > 0 then
            local distance = (position - camera.CFrame.Position).Magnitude
            local bulletTravelTime = distance / Aimbot.BulletSpeed
            
            local targetVelocity = rootPart.AssemblyLinearVelocity or rootPart.Velocity
            if targetVelocity and targetVelocity.Magnitude > 0 then
                position = position + (targetVelocity * bulletTravelTime)
            end
            
            if Aimbot.BulletDrop and Aimbot.BulletDropAmount > 0 then
                local drop = 0.5 * Aimbot.BulletDropAmount * bulletTravelTime * bulletTravelTime
                position = Vector3.new(position.X, position.Y + drop, position.Z)
            end
        end

        -- FIXED: Original responsive smoothing algorithm
        local newCFrame = CFrame.lookAt(camera.CFrame.Position, position)
        local alpha = 1 - math.pow(1 - Aimbot.Smoothness, dt * 60)
        camera.CFrame = camera.CFrame:Lerp(newCFrame, math.clamp(alpha, 0, 1))
    end)
end

local function aimbotKeyUp()
    if Aimbotting then
        Aimbotting:Disconnect()
        Aimbotting = nil
    end
    Target = nil
end

